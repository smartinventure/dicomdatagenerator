*.tmp
*.temp

# Build artifacts and generated test data
# CSV result files generated by test runs (keep directory structure, ignore contents)
test-scripts/database-seeding/test-data/csv-results/*.csv
test-scripts/database-seeding/test-data/csv-results/*.enc
# Encrypted result files (build artifacts)
*.enc
# But keep test fixtures in test-data root
!test-scripts/database-seeding/test-data/*.csv
